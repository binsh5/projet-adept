<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADEPT INFORMATIQUE NEWS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <nav id="navbar" class="sticky-top">
        <div class="container-fluid px-3 py-3 d-flex align-items-center justify-content-between">

            <span class="navbar-brand mb-0">ADEPT INFORMATIQUE</span>

            <!-- bouton mobile -->
            <button id="hamburger" class="d-md-none" onclick="toggleMenu()" aria-label="Menu">
                <img src="images/logo-ADEPT.svg" alt="logo ADEPT" id="nav-img">
            </button>

            <!-- bouton desktop -->
            <button id="hamburger-md" class="d-none d-md-flex" onclick="toggleSidebar()" aria-label="Menu">
                <img src="images/logo-ADEPT.svg" alt="logo ADEPT" id="nav-img-md">
            </button>

        </div>

        <!-- menu mobile uniquement -->
        <div id="menu" class="w-100 d-md-none">
            <ul class="list-unstyled mb-0">
                <li><a href="">Accueil</a></li>
                <li><a href="">Achat</a></li>
                <li><a href="">News</a></li>
                <li><a href="">À propos</a></li>
            </ul>
        </div>
    </nav>

    <!-- sidebar desktop uniquement -->
    <div id="sidebar">
        <ul class="list-unstyled mb-0">
            <li><a href="">Accueil</a></li>
            <li><a href="">Achat</a></li>
            <li><a href="">News</a></li>
            <li><a href="">À propos</a></li>
        </ul>
    </div>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
    <script src="nav.js"></script>
</body>

</html>